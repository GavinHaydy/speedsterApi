syntax = "v1"

info(
    title: "type title here"
    desc: "type desc here"
    author: "type author here"
    email: "type email here"
    version: "type version here"
)

type Response {
    Code int    `json:"code"`
    Msg  string `json:"msg"`
    Data interface{}    `json:"data,omitempty"`
}

type Base {
    Code int    `json:"code"`
    Msg  string `json:"msg"`
}
